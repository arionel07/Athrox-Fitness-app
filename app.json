{
	"expo": {
		"name": "FitnessUp",
		"slug": "FitnessUp",
		"version": "1.0.0",
		"orientation": "portrait",

		"scheme": "fitnessup",

		"icon": "./assets/icon.png",

		"userInterfaceStyle": "dark",

		"splash": {
			"image": "./assets/splash-icon.png",
			"resizeMode": "contain",
			"backgroundColor": "#0a0a0a"
		},

		"ios": {
			"bundleIdentifier": "com.yourname.fitnessup",
			"supportsTablet": false
		},

		"plugins": [
			"expo-router",
			"expo-sqlite",
			"expo-sharing",
			"expo-font",
			"expo-media-library"
		]
	}
}
